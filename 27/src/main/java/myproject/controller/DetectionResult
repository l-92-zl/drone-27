package myproject.controller;

import com.fasterxml.jackson.annotation.JsonProperty;
import lombok.Data;
import java.util.List;

@Data
public class DetectionResult {
    private int frameId;       // 帧号
    private long timestamp;    // 时间戳
    private int width;         // 视频宽
    private int height;        // 视频高
    private List<TargetObject> objects; // 目标列表

    @Data
    public static class TargetObject {

        // 保持 "category" 字段名，方便前端识别
        @JsonProperty("category")
        private String label;

        @JsonProperty("confidence")
        private double confidence;

        // 这样前端可以直接用 det.x, det.y
        private int x;
        private int y;
        private int w;
        private int h;

        /**
         * 模拟兼容数组的方法
         * 如果后端算法返回的是 int[]{x, y, w, h}，调用此方法自动赋值
         */
        public void setBbox(int[] bbox) {
            if (bbox != null && bbox.length >= 4) {
                this.x = bbox[0];
                this.y = bbox[1];
                this.w = bbox[2];
                this.h = bbox[3];
            }
        }
    }
}
